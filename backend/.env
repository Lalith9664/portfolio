# ─────────────────────────────────────────────────────────────────────────────
#  Environment variables for the Portfolio Backend
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────
APP_NAME="Lalith Kumar Portfolio API"
APP_VERSION="1.0.0"
DEBUG=false

# ── CORS ─────────────────────────────────
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=["http://localhost:5173","https://your-production-domain.com"]

# ── Email (Gmail SMTP) ───────────────────
# To enable contact-form emails:
#   1. Use a Gmail account (recommended: create a dedicated one)
#   2. Enable 2-Step Verification on the account
#   3. Generate an App Password at https://myaccount.google.com/apppasswords
#   4. Fill in SMTP_USER and SMTP_PASSWORD below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=lalith8302@gmail.com
SMTP_PASSWORD=vxvspztkoebajesh
CONTACT_EMAIL=lalith8302@gmail.com

# ── Rate Limiting ────────────────────────
# Max contact form submissions per IP per hour
RATE_LIMIT_CONTACT=5
